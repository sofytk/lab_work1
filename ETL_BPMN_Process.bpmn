  <process id="etl_process" name="ETL Process" isExecutable="true">
    <startEvent id="StartEvent" name="Начало ETL">
      <outgoing>Flow_0kjxopr</outgoing>
    </startEvent>
    <parallelGateway id="Gateway_0o6xvbf">
      <incoming>Flow_0kjxopr</incoming>
      <outgoing>Flow_0m9haim</outgoing>
      <outgoing>Flow_0slavus</outgoing>
    </parallelGateway>
    <serviceTask id="ExtractProjectDB" name="Берём данные из project_db">
      <incoming>Flow_0slavus</incoming>
      <outgoing>Flow_0g80l8h</outgoing>
    </serviceTask>
    <serviceTask id="ExtractResumeDB" name="Берём данные из resume_db">
      <incoming>Flow_0m9haim</incoming>
      <outgoing>Flow_ExtractResume_To_Normalize</outgoing>
    </serviceTask>
    <parallelGateway id="Gateway_0ga1x5j">
      <incoming>Flow_0g80l8h</incoming>
      <incoming>Flow_ExtractResume_To_Normalize</incoming>
      <outgoing>Flow_0yg4mso</outgoing>
    </parallelGateway>
    <serviceTask id="NormalizeNames" name="Нормализуем имена">
      <incoming>Flow_0yg4mso</incoming>
      <outgoing>Flow_Normalize_To_Match</outgoing>
    </serviceTask>
    <serviceTask id="MatchAndMerge" name="Сопоставляем имена">
      <incoming>Flow_Normalize_To_Match</incoming>
      <outgoing>Flow_Match_To_Aggregate</outgoing>
    </serviceTask>
    <serviceTask id="AggregateSkills" name="Проверяем матчинги по возрасту">
      <incoming>Flow_Match_To_Aggregate</incoming>
      <outgoing>Flow_07sxaji</outgoing>
    </serviceTask>
    <serviceTask id="ClearWarehouse" name="Очищаем data_warehouse">
      <incoming>Flow_07sxaji</incoming>
      <outgoing>Flow_Clear_To_LoadDim</outgoing>
    </serviceTask>
    <serviceTask id="LoadDimProject" name="Загружаем данные в data_warehouse">
      <incoming>Flow_Clear_To_LoadDim</incoming>
      <outgoing>Flow_LoadDim_To_LoadPerson</outgoing>
    </serviceTask>
    <endEvent id="EndSuccess" name="Success">
      <incoming>Flow_LoadDim_To_LoadPerson</incoming>
    </endEvent>
    <sequenceFlow id="Flow_0kjxopr" sourceRef="StartEvent" targetRef="Gateway_0o6xvbf" />
